# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Optional: Telegram bot token for QR login
TELEGRAM_BOT_TOKEN=

# Database path (used inside Docker container)
DATABASE_PATH=/app/data/gestao_ti.db

# Cookie Secure flag (false for HTTP-only LAN, true for HTTPS)
COOKIE_SECURE=true

# Optional: AD DNS server for resolving computer names inside Docker (e.g. 10.20.1.10)
AD_DNS_SERVER=
